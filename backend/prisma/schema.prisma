generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            Int            @id @default(autoincrement())
  email         String         @unique
  password      String
  role          String         @default("store")
  activityLogs  ActivityLog[]
}

model Article {
  id               Int               @id @default(autoincrement())
  name             String
  collection       String
  fabric           String
  season           String
  category         String            @default("General")
  description      String?
  costPrice        Float?
  sellingPrice     Float?
  isActive         Boolean           @default(true)
  createdAt        DateTime          @default(now())
  variants         Variant[]
  images           Image[]
}

model Variant {
  id           Int           @id @default(autoincrement())
  sku          String        @unique
  barcode      String?       @unique
  size         String
  type         String
  color        String
  quantity     Int           @default(0)
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  articleId    Int
  article      Article       @relation(fields: [articleId], references: [id])
  images       Image[]
  invoiceItems InvoiceItem[]
}

model StockLedger {
  id                Int      @id @default(autoincrement())
  sku               String
  movementType      String
  qty               Int
  purpose           String
  note              String?
  destination       String?
  reference         String?
  productionOrderId Int?
  createdAt         DateTime @default(now())
}

model Fabric {
  id        Int            @id @default(autoincrement())
  name      String
  type      String
  color     String
  season    String?
  meters    Float          @default(0)
  imageUrl  String?
  isActive  Boolean        @default(true)
  createdAt DateTime       @default(now())
  ledger    FabricLedger[]
}

model FabricLedger {
  id                Int      @id @default(autoincrement())
  fabricId          Int
  movementType      String
  meters            Float
  purpose           String
  note              String?
  component         String?
  productionOrderId Int?
  createdAt         DateTime @default(now())
  fabric            Fabric   @relation(fields: [fabricId], references: [id])
}

model Accessory {
  id        Int               @id @default(autoincrement())
  name      String
  category  String
  unit      String
  quantity  Float             @default(0)
  imageUrl  String?
  isActive  Boolean           @default(true)
  createdAt DateTime          @default(now())
  ledger    AccessoryLedger[]
}

model AccessoryLedger {
  id           Int       @id @default(autoincrement())
  accessoryId  Int
  movementType String
  quantity     Float
  purpose      String
  note         String?
  createdAt    DateTime  @default(now())
  accessory    Accessory @relation(fields: [accessoryId], references: [id])
}

model ActivityLog {
  id         Int      @id @default(autoincrement())
  userId     Int
  user       User     @relation(fields: [userId], references: [id])
  action     String
  entity     String
  entityId   Int?
  details    String?
  ipAddress  String?
  createdAt  DateTime @default(now())
}

model Purpose {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  type      String   @default("general")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Image {
  id        Int      @id @default(autoincrement())
  url       String
  alt       String?
  sortOrder Int      @default(0)
  articleId Int?
  article   Article? @relation(fields: [articleId], references: [id])
  variantId Int?
  variant   Variant? @relation(fields: [variantId], references: [id])
  createdAt DateTime @default(now())
}

model RolePermission {
  id         Int      @id @default(autoincrement())
  role       String
  permission String
  enabled    Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([role, permission])
}

// ============================================================
// ACCOUNTING MODULE
// ============================================================

model Account {
  id               Int               @id @default(autoincrement())
  name             String
  type             String            @default("cash")
  description      String?
  openingBalance   Float             @default(0)
  isActive         Boolean           @default(true)
  createdAt        DateTime          @default(now())
  transfersFrom    AccountTransfer[] @relation("TransferFrom")
  transfersTo      AccountTransfer[] @relation("TransferTo")
  invoicePayments  InvoicePayment[]
  expenses         Expense[]
  supplierPayments SupplierPayment[]
  advances         Advance[]
  salaryRecords    SalaryRecord[]
  labourPayments   LabourPayment[]
}

model AccountTransfer {
  id          Int      @id @default(autoincrement())
  fromAccount Account  @relation("TransferFrom", fields: [fromAccountId], references: [id])
  fromAccountId Int
  toAccount   Account  @relation("TransferTo", fields: [toAccountId], references: [id])
  toAccountId Int
  amount      Float
  note        String?
  date        DateTime @default(now())
  createdAt   DateTime @default(now())
}

model Supplier {
  id        Int               @id @default(autoincrement())
  name      String
  company   String?
  phone     String?
  email     String?
  address   String?
  note      String?
  isActive  Boolean           @default(true)
  createdAt DateTime          @default(now())
  purchases SupplierPurchase[]
  payments  SupplierPayment[]
}

model SupplierPurchase {
  id          Int                   @id @default(autoincrement())
  supplier    Supplier              @relation(fields: [supplierId], references: [id])
  supplierId  Int
  invoiceNo   String?
  description String?
  totalAmount Float
  billImage   String?
  purchaseDate DateTime            @default(now())
  createdAt   DateTime             @default(now())
  items       SupplierPurchaseItem[]
}

model SupplierPurchaseItem {
  id          Int              @id @default(autoincrement())
  purchase    SupplierPurchase @relation(fields: [purchaseId], references: [id])
  purchaseId  Int
  description String
  quantity    Float            @default(1)
  unit        String           @default("pcs")
  unitPrice   Float
  totalPrice  Float
}

model SupplierPayment {
  id          Int      @id @default(autoincrement())
  supplier    Supplier @relation(fields: [supplierId], references: [id])
  supplierId  Int
  account     Account  @relation(fields: [accountId], references: [id])
  accountId   Int
  amount      Float
  note        String?
  paymentDate DateTime @default(now())
  createdAt   DateTime @default(now())
}

model Customer {
  id        Int       @id @default(autoincrement())
  name      String
  phone     String?
  email     String?
  address   String?
  note      String?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  invoices  Invoice[]
}

model Invoice {
  id           Int              @id @default(autoincrement())
  customer     Customer         @relation(fields: [customerId], references: [id])
  customerId   Int
  invoiceNo    String           @unique
  status       String           @default("unpaid")
  discount     Float            @default(0)
  totalAmount  Float
  paidAmount   Float            @default(0)
  note         String?
  billImage    String?
  invoiceDate  DateTime         @default(now())
  createdAt    DateTime         @default(now())
  items        InvoiceItem[]
  payments     InvoicePayment[]
}

model InvoiceItem {
  id          Int      @id @default(autoincrement())
  invoice     Invoice  @relation(fields: [invoiceId], references: [id])
  invoiceId   Int
  variant     Variant? @relation(fields: [variantId], references: [id])
  variantId   Int?
  description String
  quantity    Float    @default(1)
  unitPrice   Float
  totalPrice  Float
}

model InvoicePayment {
  id            Int      @id @default(autoincrement())
  invoice       Invoice  @relation(fields: [invoiceId], references: [id])
  invoiceId     Int
  account       Account  @relation(fields: [accountId], references: [id])
  accountId     Int
  amount        Float
  note          String?
  paymentDate   DateTime @default(now())
  createdAt     DateTime @default(now())
}

model ExpenseCategory {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  type      String    @default("other")
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  expenses  Expense[]
}

model Expense {
  id          Int              @id @default(autoincrement())
  category    ExpenseCategory  @relation(fields: [categoryId], references: [id])
  categoryId  Int
  account     Account          @relation(fields: [accountId], references: [id])
  accountId   Int
  amount      Float
  description String
  billImage   String?
  collection  String?
  expenseDate DateTime         @default(now())
  createdAt   DateTime         @default(now())
}

model Employee {
  id            Int            @id @default(autoincrement())
  name          String
  designation   String?
  phone         String?
  monthlySalary Float          @default(0)
  joinDate      DateTime?
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  advances      Advance[]
  salaryRecords SalaryRecord[]
}

model Advance {
  id          Int      @id @default(autoincrement())
  employee    Employee @relation(fields: [employeeId], references: [id])
  employeeId  Int
  account     Account  @relation(fields: [accountId], references: [id])
  accountId   Int
  amount      Float
  reason      String?
  repaid      Float    @default(0)
  advanceDate DateTime @default(now())
  createdAt   DateTime @default(now())
}

model SalaryRecord {
  id              Int      @id @default(autoincrement())
  employee        Employee @relation(fields: [employeeId], references: [id])
  employeeId      Int
  account         Account  @relation(fields: [accountId], references: [id])
  accountId       Int
  month           Int
  year            Int
  baseSalary      Float
  advanceDeducted Float    @default(0)
  netSalary       Float
  isPaid          Boolean  @default(false)
  paidAt          DateTime?
  note            String?
  createdAt       DateTime @default(now())

  @@unique([employeeId, month, year])
}

model LabourPayment {
  id          Int      @id @default(autoincrement())
  account     Account  @relation(fields: [accountId], references: [id])
  accountId   Int
  workerName  String
  description String?
  note        String?
  amount      Float
  weekStart   DateTime?
  weekEnd     DateTime?
  paymentDate DateTime @default(now())
  createdAt   DateTime @default(now())
}
